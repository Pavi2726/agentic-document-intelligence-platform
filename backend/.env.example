# Groq API Configuration (REQUIRED)
GROQ_API_KEY=your_groq_api_key_here
# A safe default for local testing. Names starting with `test-` run in simulated mode.
MODEL_NAME=llama-3.3-70b-versatile
GROQ_API_TOKEN=

# LangChain / LangSmith API keys (if you use LangSmith tracing)
LANGCHAIN_API_KEY=
LANGSMITH_API_KEY=

# Neo4j Configuration (Optional - for Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# PostgreSQL Configuration (Optional - for Metadata Storage)
POSTGRES_URL=postgresql://postgres:password@localhost:5432/document_intelligence

# Redis Configuration (Optional - for Session Cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# MongoDB Configuration (Optional - for Chat History)
MONGO_URI=mongodb://localhost:27017/

# Application Settings
PROJECT_NAME=Agentic Document Intelligence Platform
UPLOAD_DIR=./uploads
VECTOR_STORE_DIR=./vector_store
